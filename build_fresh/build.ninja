# =============================================================================
# Object build statements for SHARED_LIBRARY target SDL2_mixer


#############################################
# Order-only phony target for SDL2_mixer

build cmake_object_order_depends_target_SDL2_mixer: phony || cmake_object_order_depends_target_SDL2 cmake_object_order_depends_target_opusfile cmake_object_order_depends_target_wavpack cmake_object_order_depends_target_xmp_shared

build _deps\sdl2_mixer-build\CMakeFiles\SDL2_mixer.dir\src\codecs\load_aiff.c.obj: C_COMPILER__SDL2_mixer_unscanned_Release C$:\Users\UserName\Dev\HellEngine\build_fresh\_deps\sdl2_mixer-src\src\codecs\load_aiff.c || cmake_object_order_depends_target_SDL2_mixer
  CONFIG = Release
